# ---- Backend del modelo ----
# Opciones: local (llama.cpp OpenAI-compatible) | ollama | vertex_gemini
LLM_BACKEND=local

# Endpoint local (llama.cpp servido por Docker, ver docker/01_serve_model.sh)
LOCAL_BASE_URL=http://localhost:8081/v1
LOCAL_MODEL=qwen2.5-7b-instruct
LOCAL_API_KEY=sk-no-key-required
LLM_TEMPERATURE=0

# ---- Carpeta que administra el agente (Windows Downloads desde WSL) ----
MANAGED_DIR=/mnt/c/Users/bwindows/Downloads

# ---- Seguridad ----
# false = solo lectura (recomendado). true = permite mover archivos dentro de la carpeta.
ALLOW_WRITES=false

# ---- Vertex (opcional, para conmutar de backend sin tocar codigo) ----
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash
